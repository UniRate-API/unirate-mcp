{
  "name": "@unirate/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the UniRate API — currency conversion, exchange rates, historical data, and supported-currency lookup for AI assistants.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "unirate-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:live": "UNIRATE_LIVE=1 vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unirate",
    "exchange-rates",
    "currency",
    "forex",
    "historical-rates",
    "claude",
    "anthropic",
    "ai-tools"
  ],
  "author": "Unirate Team",
  "license": "MIT",
  "homepage": "https://github.com/UniRate-API/unirate-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UniRate-API/unirate-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/UniRate-API/unirate-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
